<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.signal-platform</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/opt/python@3.11/bin/python3</string>
        <string>-m</string>
        <string>signal_platform.service</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>SIGNAL_PLATFORM_METRICS_PORT</key>
        <string>9095</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/matthew.zhao/signal-platform</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>/var/log/signal-platform/service.log</string>

    <key>StandardErrorPath</key>
    <string>/var/log/signal-platform/service.err</string>
</dict>
</plist>
